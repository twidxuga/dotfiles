# Copy stdin to the clipboard of whatever machine the terminal is on, via an
# OSC 52 escape. Over ssh this reaches the LOCAL machine's clipboard (the
# escape rides ssh -> tmux -> wezterm). base64 is BSD here so newlines are
# stripped with tr (no -w0). The byte is written to /dev/tty so it still works
# when stdout is piped/redirected. Inside tmux the sequence must be wrapped in
# tmux's DCS passthrough (ESC Ptmux; ... ESC \) with the inner ESC doubled,
# otherwise tmux swallows it. Usage: some-command | osc52-copy
function osc52-copy() {
  local b64
  b64=$(base64 | tr -d '\n') || return
  if [[ -n "$TMUX" ]]; then
    printf '\ePtmux;\e\e]52;c;%s\a\e\\' "$b64" > /dev/tty
  else
    printf '\e]52;c;%s\a' "$b64" > /dev/tty
  fi
}

# Under SSH, redirect browser opens to the laptop (via ~/Scripts/url-forward,
# which emits the wezterm SetUserVar escape). macOS `open` ignores $BROWSER (it
# uses LaunchServices), so we shadow it: a lone http(s) url is forwarded to the
# laptop; everything else (files, `open .`, `open -a App`, any flag) falls
# through to the real /usr/bin/open. $BROWSER/$GH_BROWSER cover the tools that
# DO honour them (gh, python webbrowser, npm's open); git is covered via its own
# web.browser config. The absolute path is used because ~/Scripts is not on PATH
# and $BROWSER-consumers exec their value (a shell function would be invisible).
# All guarded by SSH so local Mac use is intact.
if [[ -n "$SSH_CONNECTION" ]]; then
  function open() {
    if [[ $# -eq 1 ]]; then
      case "$1" in
        http://*|https://*) "$HOME/Scripts/url-forward" "$1"; return ;;
      esac
    fi
    command open "$@"
  }
  export BROWSER="$HOME/Scripts/url-forward"
  export GH_BROWSER="$HOME/Scripts/url-forward"
  git config --global web.browser url-forward 2>/dev/null
  git config --global browser.url-forward.cmd "$HOME/Scripts/url-forward %s" 2>/dev/null
fi

# tmux aliases
alias mux='tmuxinator'
function tma() {
  if [[ "$#" -eq 1 ]]
  then
    # Attaches to or creates a new named sassion
    if [[ -n "$TMUX" ]]
    then 
      tmux new -d "tmuxinator start $1 --suppress-tmux-version-warning=SUPPRESS-TMUX-VERSION-WARNING || tmux new-session -A -s $1"
    else
      tmuxinator start $1 --suppress-tmux-version-warning=SUPPRESS-TMUX-VERSION-WARNING || tmux new-session -A -s $1
    fi
    return
  fi
  if [[ $(tmux list-sessions | wc -l) -gt 0 ]]
  then
    tmux attach
  else 
    echo "======== No sessions to attach to! ========"
    #tmux new-session
  fi
}

# Nodenv lazy loading
function nodenv() {
  if [[ $(which nodenv | grep "UNIQUENODEENVXPTOFOO") != "" ]]
  then
    nodenvcmd="/usr/bin/nodenv"
    macnodenvcmd="/run/current-system/sw/bin/nodenv"
    if [[ -f $macnodenvcmd ]]
    then
      nodenvcmd=$macnodenvcmd
    fi 
    eval "$("${nodenvcmd}" init -)"
  fi
  nodenv "$@"
}

# Lazy loading pyenv based on github.com/davidparsson/zsh-pyenv-lazy
if type pyenv > /dev/null; then
    function pyenv() {
        # export PATH="${PYENV_ROOT}/bin:${PYENV_ROOT}/shims:${PATH}"
        unset -f pyenv
        eval "$(command pyenv init -)"
        # set ZSH_PYENV_LAZY_VIRTUALENV to true to initialize virtualenv 
        if [[ -n "${ZSH_PYENV_LAZY_VIRTUALENV}" ]]; then
            eval "$(command pyenv virtualenv-init -)"
        fi
        pyenv $@
    }
fi

