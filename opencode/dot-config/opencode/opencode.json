{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "**/node_modules/**",
      "dist/**",
      "**/dist/**",
      "build/**",
      "**/build/**",
      ".git/**",
      "**/*.log",
      ".next/**",
      "**/.next/**",
      ".nuxt/**",
      "**/.nuxt/**",
      ".turbo/**",
      "**/.turbo/**",
      ".cache/**",
      "**/.cache/**",
      "**/.output/**",
      "**/coverage/**",
      "bun.lock",
      "package-lock.json",
      "opencode-mem-*.tgz",
      "**/opencode-mem-*.tgz",
      "dcp.jsonc"
    ]
  },
  "agent": {
    "reflection": {
      "description": "Personal coach for career reflections, workplace challenges, professional growth, and all life challenges.",
      "model": "anthropic/claude-sonnet-4-6",
      "reasoningEffort": "high",
      "prompt": "You are a thoughtful career coach and mentor specializing in software engineering careers. Help with workplace dynamics, career growth, performance concerns, and professional development. Provide empathetic but direct guidance. Beyond that you are an empathetic friend who genuinly wants to help, no matter the subject."
    }
  },
  "mcp": {
    "mcp_hub": {
      "type": "remote",
      "url": "http://localhost:37373/mcp"
    }
  },
  "plugin": [
    "oh-my-openagent",
    "@franlol/opencode-md-table-formatter",
    "opencode-mem",
    "opencode-rules",
    "@ramtinj95/opencode-tokenscope@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "timeout": 300000
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5"
        },
        "o3": {
          "name": "o3"
        },
        "o4-mini": {
          "name": "o4-mini"
        },
        "codex-1": {
          "name": "Codex-1"
        }
      }
    },
    "anthropic": {
      "options": {
        "timeout": 600000,
        "headers": {
          "anthropic-beta": "context-1m-2025-08-07"
        }
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (1M)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (1M)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (1M)",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        }
      }
    }
  }
}